{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "usageCount": { "type": "number", "description": "Number of images generated" },
        "isAuthorized": { "type": "boolean", "description": "Whether the user has entered a valid code" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "usageCount", "isAuthorized", "role"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Codes generated by admin to grant access",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" }
      },
      "required": ["code", "createdBy", "createdAt", "isUsed"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User data"
    },
    "/access_codes/{code}": {
      "schema": "AccessCode",
      "description": "Available access codes"
    }
  }
}
